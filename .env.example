# Eden Workspace Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/eden

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API Server
API_PORT=3000
API_URL=http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:3000
APP_URL=http://localhost:3000

# AI Integrations (Groq)
AI_INTEGRATIONS_GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_INTEGRATIONS_GROQ_API_KEY=your-groq-api-key

# AI Integrations (OpenAI)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key

# Cloudinary (for media storage)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Dropbox OAuth
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret

# OneDrive OAuth (future)
# ONEDRIVE_CLIENT_ID=your-onedrive-client-id
# ONEDRIVE_CLIENT_SECRET=your-onedrive-client-secret
